{% extends 'base.html.twig' %}

{% block title %}Page{% endblock %}

{% block body %}
    <h1>Page {{ page.titleJson.fr }}</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ page.id }}</td>
            </tr>
            <tr>
                <th>Titre</th>
                <td>{{ page.titleJson ? page.titleJson.fr : '' }}</td>
            </tr>
            <tr>
                <th>Contenu</th>
                <td>{{ page.contentJson ? page.contentJson.fr : '' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_page_index') }}">Retour à la liste</a>

    {% if 'ROLE_ADMIN' in app.user.roles %}

    <a href="{{ path('app_page_edit', {'id': page.id}) }}">Éditer</a>

    {{ include('page/_delete_form.html.twig') }}

    {% endif %}
{% endblock %}
