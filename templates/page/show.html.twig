{% extends 'base.html.twig' %}

{% block title %}Page{% endblock %}

{% block body %}
    <h1>Page</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ page.id }}</td>
            </tr>
            <tr>
                <th>TitleJson</th>
                <td>{{ page.titleJson ? page.titleJson|json_encode : '' }}</td>
            </tr>
            <tr>
                <th>ContentJson</th>
                <td>{{ page.contentJson ? page.contentJson|json_encode : '' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_page_index') }}">back to list</a>

    <a href="{{ path('app_page_edit', {'id': page.id}) }}">edit</a>

    {{ include('page/_delete_form.html.twig') }}
{% endblock %}
