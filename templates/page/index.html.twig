{% extends 'base.html.twig' %}

{% block title %}Page index{% endblock %}

{% block body %}
    <h1>Page index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Titre</th>
                <th>Contenu</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for page in pages %}
            <tr>
                <td>{{ page.id }}</td>
                <td>{{ page.titleJson ? page.titleJson.fr : '' }}</td>
                <td>{{ page.contentJson ? page.contentJson.fr : '' }}</td>
                <td>
                    <a href="{{ path('app_page_show', {'id': page.id}) }}">show</a>
                    {% if 'ROLE_ADMIN' in app.user.roles %}
                    <a href="{{ path('app_page_edit', {'id': page.id}) }}">edit</a>
                    {% endif %}
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="4">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    {% if 'ROLE_ADMIN' in app.user.roles %}
        <a href="{{ path('app_page_new') }}">Create new</a>
    {% endif %}
{% endblock %}
