{% extends 'base.html.twig' %}

{% block title %}Inventory{% endblock %}

{% block main %}
    <h1>Inventory</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ inventory.id }}</td>
            </tr>
            <tr>
                <th>Catégorie</th>
                <td>{{ inventory.category.titleJson.fr }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_inventory_index') }}">Retour à la liste</a>

    <a href="{{ path('app_inventory_edit', {'id': inventory.id}) }}">Éditer</a>

    {{ include('inventory/_delete_form.html.twig') }}
{% endblock %}
