<form method="post" action="{{ path('app_section_delete', {'id': section.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer la section {{section.titleJson.fr}} ?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ section.id) }}">
    <button class="btn">Supprimer la section</button>
</form>
