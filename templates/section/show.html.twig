{% extends 'base.html.twig' %}

{% block title %}Section{% endblock %}

{% block main %}
    <h1>Section {{ section.titleJson.fr }}</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ section.id }}</td>
            </tr>
            <tr>
                <th>Titre</th>
                <td>{{ section.titleJson ? section.titleJson|join(', ') : '' }}</td>
            </tr>
        </tbody>
    </table>
    <ul>
        {% for chapter in section.chapters %}
        <li><a href={{path('app_chapter_show', {id: chapter.id})}}>{{chapter.category.titleJson.fr}}</a></li>
        {% endfor %}
    </ul>
    <a href="{{ path('app_section_index') }}">Retour à la liste</a>

    {% if app.user and 'ROLE_ADMIN' in app.user.roles %}
        <a href="{{ path('app_section_edit', {'id': section.id}) }}">Éditer</a>
        {{ include('section/_delete_form.html.twig') }}
    {% endif %}

{% endblock %}
