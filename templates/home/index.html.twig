{% extends 'base.html.twig' %}

{% block title %}Home{% endblock %}


{% block main %}
        <p> Développez vos compétences de programmation web à l'aide de leçons disponibles gratuitement.</p>
        <section class="newestPages">
            <h2>Nouveautés</h2>
                <div class="newPagesList">
                    {% for chapter in chapters %}
                        <a href={{path("app_chapter_show", {id: chapter.id})}}>
                            <div>
                                <p>{{chapter.category.titleJson.fr}} </p>
                            </div>
                        </a>
                    {% endfor %}
                </div>
        </section>
{% endblock %}
