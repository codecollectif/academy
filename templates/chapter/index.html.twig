{% extends 'base.html.twig' %}

{% block title %}Chapter index{% endblock %}

{% block main %}
    <h1>Liste des chapitres</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Catégorie</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for chapter in chapters %}
            <tr>
                <td>{{ chapter.id }}</td>
                <td>{{ chapter.category.titleJson.fr }}</td>
                <td>
                    <a href="{{ path('app_chapter_show', {'id': chapter.id}) }}">Plus d'infos</a>
                    {% if app.user and 'ROLE_ADMIN' in app.user.roles %}
                        <a href="{{ path('app_chapter_edit', {'id': chapter.id}) }}">Éditer</a>
                    {% endif %}
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="2">Aucune entrée disponible</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    {% if app.user and 'ROLE_ADMIN' in app.user.roles %}
        <a href="{{ path('app_chapter_new') }}">Ajouter un nouveau chapitre</a>
    {% endif %}
{% endblock %}
