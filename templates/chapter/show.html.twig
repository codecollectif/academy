{% extends 'base.html.twig' %}

{% block title %}Chapter{% endblock %}

{% block main %}
    <h1>Chapitre {{ chapter.category.titleJson.fr }}</h1>

    {% if app.user and 'ROLE_ADMIN' in app.user.roles %}
        <a href="{{ path('app_chapter_edit', {'id': chapter.id}) }}">Modifier le chapitre</a>
        {{ include('chapter/_delete_form.html.twig') }}
        <a href="{{ path('app_page_new', {id: chapter.category.id}) }}">Ajouter une nouvelle page au chapitre</a>
    {% endif %}

    <ul>
        {% for page in chapter.category.pages %}
        <li><a href={{path('app_page_show', {id: page.id})}}>{{page.titleJson.fr}}</a></li>
        {% endfor %}
    </ul>

    <a href="{{ path('app_section_show', {id: chapter.section.id}) }}">Retour</a>
{% endblock %}
