{% extends 'base.html.twig' %}

{% block title %}Chapter{% endblock %}

{% block main %}
    <h1>Chapitre {{ chapter.category.titleJson.fr }}</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ chapter.id }}</td>
            </tr>
            <tr>
                <th>Titre</th>
                <td>{{ chapter.category.titleJson.fr }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_chapter_index') }}">Retour à la liste</a>

    <a href="{{ path('app_chapter_edit', {'id': chapter.id}) }}">Éditer</a>

    {{ include('chapter/_delete_form.html.twig') }}
{% endblock %}
