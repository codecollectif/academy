<nav>
    <div class="navheader">
        Site
    </div>
    <ul>
        <li class="home">
            <a href={{ path('app_home') }}>Accueil</a>
        </li>
        <li class="pages">
            <a href={{ path(app.user ? 'app_page_index' : 'app_login') }}>Pages</a>
        </li>
        {% if app.user %}
        <li class="authentification">
            <a href={{ path('app_logout') }}> Se déconnecter</a>
        </li>
        {% else %}
        <li class="authentification">
            <a href={{ path('app_login') }}> Se connecter</a>
        </li>
        {% endif %}
    </ul>
    {% if app.user %}
    <div class="email">
        {{ app.user.email }}
    </div>
    {% endif %}
</nav>